// Serve uploads directory with proper headers
app.use('/uploads', express.static(uploadsDir, {
  setHeaders: (res, filePath) => {
    if (filePath.endsWith('.glb')) {
      res.setHeader('Content-Type', 'model/gltf-binary');
    } else if (filePath.endsWith('.gltf')) {
      res.setHeader('Content-Type', 'model/gltf+json');
    } else if (filePath.endsWith('.ifc')) {
      res.setHeader('Content-Type', 'application/octet-stream');
    }
  },
  etag: false,
  lastModified: false
}));

// File upload endpoint
app.post('/api/upload', upload.single('file'), async (req, res) => {
  if (!req.file) {
    return sendResponse(res, 400, { code: 400, msg: 'No file uploaded', success: false });
  }

  const projectId = String(req.body?.projectId || req.query?.projectId || req.headers['x-project-id'] || 'default').trim();
  const relativePath = path.relative(uploadsDir, req.file.path).split(path.sep).join('/');
  const encodedRelativePath = relativePath
    .split('/')
    .map((seg) => encodeURIComponent(seg))
    .join('/');
  const fileUrl = `/uploads/${encodedRelativePath}`;
  
  try {
    const inferredType = inferAssetTypeFromFileName(req.file.originalname || '');

    const assetEntry = {
      id: `asset-${Date.now()}`,
      name: req.file.originalname,
      type: inferredType,
      url: fileUrl,
      size: formatAssetSize(req.file.size),
      uploadDate: new Date().toISOString().split('T')[0],
    };

    try {
      await pool.query(
        `UPDATE projects
           SET digital_assets = COALESCE(digital_assets, '[]'::jsonb) || jsonb_build_array($2::jsonb)
         WHERE id = $1 OR lower(id) = lower($1)`,
        [projectId, JSON.stringify(assetEntry)]
      );
    } catch (e) {
      console.warn('[upload] append to projects.digital_assets failed:', (e as any)?.message || e);
    }

    try {
      const cols = await getProjectFilesColumns();
      const fields: string[] = ['project_id', 'file_name', 'file_path'];
      const placeholders: string[] = ['$1', '$2', '$3'];
      const values: any[] = [projectId, req.file.originalname, fileUrl];
      let idx = 4;
      if (cols.has('file_size')) {
        fields.push('file_size'); placeholders.push(`$${idx++}`); values.push(req.file.size);
      }
      if (cols.has('file_type')) {
        fields.push('file_type'); placeholders.push(`$${idx++}`); values.push(req.file.mimetype || inferredType);
      }
      await pool.query(
        `INSERT INTO project_files (${fields.join(', ')}) VALUES (${placeholders.join(', ')})`,
        values
      );
    } catch (e) {
      console.warn('[upload] insert project_files failed:', (e as any)?.message || e);
    }

    return sendResponse(res, 200, {
      code: 200,
      success: true,
      msg: 'File uploaded successfully',
      data: {
        filename: req.file.filename,
        originalname: req.file.originalname,
        path: fileUrl,
        url: fileUrl,
        size: req.file.size,
        type: req.file.mimetype,
        projectId,
        asset: assetEntry,
      }
    });
  } catch (error) {
    console.error('Upload error:', error);
    return sendResponse(res, 500, { code: 500, msg: 'Upload failed', success: false });
  }
});

// 按项目目录一键回填 digital_assets（用于历史数据修复）
app.post('/api/admin/backfill-project-assets', async (req, res) => {
  try {
    const projectId = String(req.body?.projectId || '').trim();
    if (!projectId) {
      return sendResponse(res, 400, { code: 400, success: false, msg: 'projectId is required' });
    }

    const resolved = resolveProjectUploadDir(projectId);
    if (!resolved) {
      return sendResponse(res, 404, { code: 404, success: false, msg: `目录不存在：${path.join(uploadsDir, projectId)}` });
    }

    const assets = listAssetsFromProjectDir(resolved.dirName, `asset-backfill-${Date.now()}`);

    await pool.query(
      `UPDATE projects SET digital_assets = $1::jsonb WHERE id = $2 OR lower(id) = lower($2)`,
      [JSON.stringify(assets), projectId]
    );

    return sendResponse(res, 200, {
      code: 200,
      success: true,
      msg: 'backfill success',
      data: { projectId, count: assets.length, assets }
    });
  } catch (error) {
    console.error('/api/admin/backfill-project-assets 错误：', error);
    return sendResponse(res, 500, { code: 500, success: false, msg: 'backfill failed' });
  }
});

let projectFilesColumnsCache: { cols: Set<string>; cachedAt: number } | null = null;
const getProjectFilesColumns = async () => {
  const now = Date.now();
  if (projectFilesColumnsCache && now - projectFilesColumnsCache.cachedAt < 60_000) {
    return projectFilesColumnsCache.cols;
  }
  const result = await pool.query(
    `SELECT column_name
       FROM information_schema.columns
      WHERE table_schema = 'public' AND table_name = 'project_files'`
  );
  const cols = new Set<string>(result.rows.map((row: any) => String(row.column_name || '').trim()));
  projectFilesColumnsCache = { cols, cachedAt: now };
  return cols;
};

const parseJsonArraySafe = (value: any): any[] => {
  if (Array.isArray(value)) return value;
  if (!value) return [];
  try {
    const parsed = typeof value === 'string' ? JSON.parse(value) : value;
    return Array.isArray(parsed) ? parsed : [];
  } catch {
    return [];
  }
};

app.get('/api/projects', async (req, res) => {
  try {
    let whereClause = '';
    const params: any[] = [];
    const brand_id = String(req.query?.brand_id || '').trim();
    if (brand_id) {
      whereClause = ' WHERE (client_name = $1 OR brand_id = $1)';
      params.push(brand_id);
    }

    let query = `SELECT * FROM projects${whereClause}`;
    query += ' ORDER BY created_at DESC';
    
    const result = await pool.query(query, params);
    const projects = result.rows;

    const projectIds = result.rows.map((row: any) => String(row.id || '')).filter(Boolean);
    const filesByProjectId = new Map<string, any[]>();
    if (projectIds.length > 0) {
      try {
        const cols = await getProjectFilesColumns();
        const selectCols = [
          'project_id',
          'file_name',
          'file_path',
          cols.has('file_size') ? 'file_size' : null,
          cols.has('file_type') ? 'file_type' : null,
          cols.has('upload_time') ? 'upload_time' : null,
        ].filter(Boolean).join(', ');
        const fileResult = await pool.query(
          `SELECT ${selectCols} FROM project_files WHERE project_id = ANY($1::text[]) ORDER BY COALESCE(upload_time, NOW()) DESC`,
          [projectIds]
        );
        for (const fileRow of fileResult.rows) {
          const pid = String((fileRow as any).project_id || '');
          if (!pid) continue;
          const list = filesByProjectId.get(pid) || [];
          list.push(fileRow);
          filesByProjectId.set(pid, list);
        }
      } catch (e) {
        console.warn('[projects] project_files fallback query failed:', (e as any)?.message || e);
      }
    }

    const mapped = result.rows.map(row => {
      let digitalAssets = parseJsonArraySafe(row.digital_assets);
      if (digitalAssets.length === 0) {
        const fallbackFiles = filesByProjectId.get(String(row.id || '')) || [];
        digitalAssets = fallbackFiles.map((fileRow: any, idx: number) => {
          const fileName = String(fileRow.file_name || '').trim() || `file-${idx + 1}`;
          const filePath = String(fileRow.file_path || '').trim();
          const normalizedUrl = filePath.startsWith('/uploads/')
            ? filePath
            : filePath.startsWith('uploads/')
              ? `/${filePath}`
              : filePath.includes('/uploads/')
                ? filePath.slice(filePath.indexOf('/uploads/'))
                : filePath || '#';
          const type = inferAssetTypeFromFileName(fileName);
          const sizeLabel = formatAssetSize(fileRow.file_size);
          const uploadDate = fileRow.upload_time
            ? new Date(fileRow.upload_time).toISOString().split('T')[0]
            : new Date().toISOString().split('T')[0];
          return {
            id: `pf-${row.id}-${idx}`,
            name: fileName,
            type,
            url: normalizedUrl,
            size: sizeLabel,
            uploadDate,
          };
        });
      }
      if (digitalAssets.length === 0) {
        digitalAssets = listAssetsFromProjectDir(String(row.id || ''), 'fs');
      }
      if (digitalAssets.length === 0) {
        digitalAssets = findAssetsByLooseProjectMatch(row);
      }

      return {
        ...row,
        digitalAssets,
        digital_assets: digitalAssets,
      };
    });

    sendResponse(res, 200, { code: 200, msg: 'success', data: mapped });
  } catch (error) {
    console.error('Get projects error:', error);
    sendResponse(res, 500, { code: 500, msg: 'Failed to get projects', success: false });
  }
});

