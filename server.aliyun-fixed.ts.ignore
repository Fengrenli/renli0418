// Ensure uploads directory exists
const uploadsDir = path.join(__dirname, 'uploads');
if (!fs.existsSync(uploadsDir)) {
  fs.mkdirSync(uploadsDir, { recursive: true });
}

type AssetKind = 'model' | 'pdf' | 'image' | 'video' | 'contract' | 'link' | 'list' | 'rvt';

const inferAssetTypeFromFileName = (fileName: string): AssetKind => {
  const lower = String(fileName || '').toLowerCase();
  if (lower.endsWith('.pdf')) return 'pdf';
  if (lower.endsWith('.rvt')) return 'rvt';
  if (/\.(glb|gltf|fbx|obj|ifc|dwg|skp|nwd)$/.test(lower)) return 'model';
  if (/\.(jpg|jpeg|png|webp|gif)$/.test(lower)) return 'image';
  if (/\.(mp4|mov|avi|webm)$/.test(lower)) return 'video';
  if (/\.(doc|docx|xls|xlsx|ppt|pptx)$/.test(lower)) return 'contract';
  return 'list';
};

const formatAssetSize = (size: number | undefined | null) => {
  return Number.isFinite(Number(size)) && Number(size) > 0
    ? `${(Number(size) / 1024 / 1024).toFixed(2)} MB`
    : '--';
};

const buildUploadsUrl = (...segments: string[]) => {
  return `/uploads/${segments.map((seg) => encodeURIComponent(String(seg || '').trim())).filter(Boolean).join('/')}`;
};

const resolveProjectUploadDir = (projectId: string) => {
  const normalizedProjectId = String(projectId || '').trim();
  if (!normalizedProjectId || !fs.existsSync(uploadsDir)) return null;

  const exactDir = path.join(uploadsDir, normalizedProjectId);
  if (fs.existsSync(exactDir) && fs.statSync(exactDir).isDirectory()) {
    return { dirName: normalizedProjectId, dirPath: exactDir };
  }

  try {
    const matched = fs
      .readdirSync(uploadsDir, { withFileTypes: true })
      .find((entry) => entry.isDirectory() && entry.name.toLowerCase() === normalizedProjectId.toLowerCase());
    if (!matched) return null;
    return { dirName: matched.name, dirPath: path.join(uploadsDir, matched.name) };
  } catch {
    return null;
  }
};

const listAssetsFromProjectDir = (projectId: string, assetIdPrefix = 'asset-fs') => {
  const resolved = resolveProjectUploadDir(projectId);
  if (!resolved) return [];

  const nowDate = new Date().toISOString().split('T')[0];

  try {
    return fs
      .readdirSync(resolved.dirPath)
      .map((fileName) => {
        const fullPath = path.join(resolved.dirPath, fileName);
        try {
          const stat = fs.statSync(fullPath);
          if (!stat.isFile()) return null;
          return {
            fileName,
            stat,
          };
        } catch {
          return null;
        }
      })
      .filter((entry): entry is { fileName: string; stat: fs.Stats } => Boolean(entry))
      .sort((a, b) => b.stat.mtimeMs - a.stat.mtimeMs)
      .map((entry, idx) => ({
        id: `${assetIdPrefix}-${resolved.dirName}-${idx}`,
        name: entry.fileName,
        type: inferAssetTypeFromFileName(entry.fileName),
        url: buildUploadsUrl(resolved.dirName, entry.fileName),
        size: formatAssetSize(entry.stat.size),
        uploadDate: entry.stat.mtime
          ? new Date(entry.stat.mtime).toISOString().split('T')[0]
          : nowDate,
      }));
  } catch {
    return [];
  }
};

const listAssetsFromDefaultDir = (assetIdPrefix = 'asset-default') => {
  const defaultDir = path.join(uploadsDir, 'default');
  if (!fs.existsSync(defaultDir)) return [];

  const nowDate = new Date().toISOString().split('T')[0];

  try {
    return fs
      .readdirSync(defaultDir)
      .map((fileName) => {
        const fullPath = path.join(defaultDir, fileName);
        try {
          const stat = fs.statSync(fullPath);
          if (!stat.isFile()) return null;
          return { fileName, stat };
        } catch {
          return null;
        }
      })
      .filter((entry): entry is { fileName: string; stat: fs.Stats } => Boolean(entry))
      .sort((a, b) => b.stat.mtimeMs - a.stat.mtimeMs)
      .map((entry, idx) => ({
        id: `${assetIdPrefix}-${idx}`,
        name: entry.fileName,
        type: inferAssetTypeFromFileName(entry.fileName),
        url: buildUploadsUrl('default', entry.fileName),
        size: formatAssetSize(entry.stat.size),
        uploadDate: entry.stat.mtime
          ? new Date(entry.stat.mtime).toISOString().split('T')[0]
          : nowDate,
      }));
  } catch {
    return [];
  }
};

const findAssetsByLooseProjectMatch = (project: any) => {
  const assets = listAssetsFromDefaultDir();
  if (assets.length === 0) return [];

  const normalize = (value: any) =>
    String(value || '')
      .toLowerCase()
      .replace(/\.[a-z0-9]+$/i, '')
      .replace(/[-_]+/g, ' ')
      .replace(/\s+/g, ' ')
      .trim();

  const candidateTokens = new Set<string>();
  const pushTokens = (value: any) => {
    const normalized = normalize(value);
    if (!normalized) return;
    candidateTokens.add(normalized);
    normalized
      .split(' ')
      .map((part) => part.trim())
      .filter((part) => part.length >= 2)
      .forEach((part) => candidateTokens.add(part));
  };

  pushTokens(project?.name);
  pushTokens(project?.client_name);
  pushTokens(project?.clientName);
  pushTokens(project?.location);
  pushTokens(project?.city);
  pushTokens(project?.country);

  const tokens = Array.from(candidateTokens).filter(Boolean);
  if (tokens.length === 0) return [];

  return assets.filter((asset) => {
    const haystack = normalize(asset.name);
    return tokens.some((token) => token.length >= 2 && haystack.includes(token));
  });
};

// Multer configuration
const storage = multer.diskStorage({
  destination: (req, file, cb) => {
    const projectId = String(req.body?.projectId || req.query?.projectId || req.headers['x-project-id'] || 'default').trim();
    const projectUploadsDir = path.join(uploadsDir, projectId);
    if (!fs.existsSync(projectUploadsDir)) {
      fs.mkdirSync(projectUploadsDir, { recursive: true });
    }
    cb(null, projectUploadsDir);
  },
  filename: (req, file, cb) => {
    const uniqueSuffix = Date.now() + '-' + Math.round(Math.random() * 1E9);
    // 处理文件名，确保编码正确
    const safeFileName = Buffer.from(file.originalname, 'latin1').toString('utf8');
    cb(null, uniqueSuffix + '-' + safeFileName);
  }
});

const upload = multer({ 
  storage,
  limits: {
    fileSize: 100 * 1024 * 1024 // 100MB limit
  }
});

const corsOrigin = process.env.CORS_ORIGIN || true;
app.use(cors({ origin: corsOrigin, credentials: true }));
app.use(express.json({ limit: '20mb' }));
app.use(express.urlencoded({ extended: true, limit: '20mb' }));

