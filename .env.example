# 阿里云 RDS / PolarDB PostgreSQL（端口 5432，勿用 3306）
DB_HOST=pgs-xxxx.polardb.aliyuncs.com
DB_PORT=5432
DB_USER=你的数据库用户名
DB_PASSWORD=你的数据库密码
# 库名（与 db.js 一致：可用 DB_NAME 或 DB_DATABASE）
DB_NAME=你的库名

# BOM 算量规则：设为 1 时，下次启动会先 TRUNCATE assembly_rules（含 rule_items）再注入白名单。用完请改回 0 或删除，避免每次清空。
# 做 materials 全表重编码期间建议保持关闭，以免启动时覆盖你手工对齐后的 rule_items。
# BOM_RULES_RESEED=1

# 服务器端口（默认 3800，见 server.ts；与下方示例 3000 不一致时请以实际为准）
SERVER_PORT = 3000
# Vite 热更新 WebSocket 端口；若终端报「Port 24678 is already in use」可改为 24679 或关掉重复的 npm run dev
# VITE_HMR_PORT=24679（默认已 24679；仅当仍冲突时再改）

# 勿在 .env 写 NODE_ENV / VITE_DEV（由 npm 脚本设置）。
# 本地必须：npm run dev（VITE_DEV=1 才走 Vite）；仅 npm start 或 VITE_DEV=0 时会读 dist（浏览器里多为 index-xxxxx.js）。
# 开发时 npm run dev 会在加载 .env 后再加载 .env.development（不覆盖已有键），便于把密钥只放在 .env.development。

# 通义千问 / DashScope（仅服务端使用；BOM HS 编码走 POST /api/ai/suggest-hscode，勿使用 VITE_ 前缀以免泄露到浏览器）
# TONGYI_API_KEY=
# 或 DASHSCOPE_API_KEY=
# TONGYI_MODEL=qwen-turbo

# 管理员 Token 密钥（可选，用于 JWT 加密）
JWT_SECRET = your_secret_key_123456

# 地理编码：国内若无法访问 Nominatim，可保留默认（已自动降级 Open-Meteo，无需 Key）
# NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
# GEOCODE_DISABLE_OPEN_METEO_FALLBACK=1
# 单次请求超时（毫秒），默认 45000（避免 undici 默认 10s 频繁超时）
# GEOCODE_FETCH_TIMEOUT_MS=45000
# Nominatim 几乎不可达时，可先只用 Open-Meteo（推荐国内跑批）
# GEOCODE_PREFER_OPEN_METEO=1

# 批量地理补全（POST /api/admin/backfill-project-geocodes 或 npm run backfill:geo）
# 请使用足够长的随机串；请求时带 Header: x-backfill-secret: <同值>
BACKFILL_GEO_SECRET =

# 可选：脚本 backfill:geo 每次从库拉取行数上限、本轮尝试条数
# BACKFILL_FETCH_LIMIT = 800
# BACKFILL_MAX_ATTEMPTS = 40
# 列出缺坐标项目时最多扫描行数（按 created_at 倒序）
# BACKFILL_LIST_LIMIT = 5000

# --- 前端（Vite，需以 VITE_ 开头才会注入浏览器）---
# 正式域名，无尾斜杠；用于运行时写入 canonical、og:url（不配则跳过）
# VITE_SITE_URL=https://www.example.com
# Open Graph / Twitter 分享图，绝对 URL 或以 / 开头的站内路径（需同时配置 VITE_SITE_URL）
# VITE_OG_IMAGE_URL=/og-image.png
# 页脚联系（不配则使用代码内默认值）
# VITE_CONTACT_EMAIL=hello@example.com
# VITE_CONTACT_PHONE=+86 13800138000
# 可选：若显示格式与 tel: 不一致时单独写拨号链接（默认按 +86 手机号推导）
# VITE_CONTACT_PHONE_TEL=tel:+8613800138000
# 社交媒体（可选）
# VITE_SOCIAL_LINKEDIN=
# VITE_SOCIAL_INSTAGRAM=
# VITE_SOCIAL_WECHAT=
# 设计编辑器入口（默认 /editor/，支持同域路径或完整 https URL）
# VITE_EDITOR_URL=/editor/
# 设计编辑器桌面版下载入口（默认 /downloads/rdesign/latest/）
# VITE_EDITOR_DESKTOP_URL=/downloads/rdesign/latest/
# 高德地图（管理后台等前端组件，可公开 Key 时配域名白名单）
# VITE_AMAP_API_KEY=